{
  "name": "automend-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "install-all": "npm install && npm install --workspaces",
    "dev:client": "npm run dev --workspace=client",
    "dev:server": "npm run dev --workspace=server",
    "dev": "concurrently --kill-others -n \"client,server\" -c \"cyan,magenta\" \"npm run dev:client\" \"npm run dev:server\"",
    "build:client": "npm run build --workspace=client",
    "build-all": "npm run build:client",
    "start:server": "npm start --workspace=server",
    "start": "npm run start:server"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
